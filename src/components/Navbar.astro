---
import ThemeToggle from './ThemeToggle.astro';

const currentPath = Astro.url.pathname;

const menuItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Academics', href: '/academics' },
  { label: 'Faculty', href: '/teaching-staff' },
  { label: 'Contact', href: '/contact' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<nav class="navbar" role="navigation" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/" class="logo" aria-label="JNV Homepage">
      <div class="logo-emblem">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L2 7l10 5 10-5-10-5z"/>
          <path d="M2 17l10 5 10-5"/>
          <path d="M2 12l10 5 10-5"/>
        </svg>
      </div>
      <div class="logo-text">
        <span class="logo-title">JNV</span>
        <span class="logo-subtitle">Jawahar Navodaya Vidyalaya</span>
      </div>
    </a>

    <div class="nav-drawer" id="navDrawer" role="dialog" aria-modal="true" aria-label="Navigation menu">
      <div class="drawer-header">
        <span class="drawer-title">Menu</span>
        <button class="drawer-close" id="drawerClose" aria-label="Close menu">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <ul class="nav-links" role="menubar">
        {menuItems.map((item) => (
          <li role="none">
            <a
              href={item.href}
              role="menuitem"
              class:list={{ 'nav-link': true, active: isActive(item.href) }}
            >
              <span class="nav-label">{item.label}</span>
              <span class="nav-indicator"></span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="nav-right">
      <ul class="nav-links-desktop" role="menubar">
        {menuItems.map((item) => (
          <li role="none">
            <a
              href={item.href}
              role="menuitem"
              class:list={{ 'nav-link': true, active: isActive(item.href) }}
            >
              <span class="nav-label">{item.label}</span>
              <span class="nav-indicator"></span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="nav-end">
      <ThemeToggle />
      <button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false" aria-controls="navDrawer">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

<script>
  const hamburger = document.getElementById('hamburger');
  const drawer = document.getElementById('navDrawer');
  const closeBtn = document.getElementById('drawerClose');

  function openDrawer() {
    drawer.classList.add('open');
    hamburger.classList.add('active');
    hamburger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    drawer.classList.remove('open');
    hamburger.classList.remove('active');
    hamburger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  if (hamburger && drawer && closeBtn) {
    hamburger.addEventListener('click', () => {
      drawer.classList.contains('open') ? closeDrawer() : openDrawer();
    });
    closeBtn.addEventListener('click', closeDrawer);
    drawer.querySelectorAll('a').forEach(function(link) {
      link.addEventListener('click', closeDrawer);
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && drawer.classList.contains('open')) closeDrawer();
    });
  }
</script>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg-nav);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--border-nav);
    height: 68px;
    transition: background 0.3s, border-color 0.3s, box-shadow 0.3s;
  }

  .nav-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo-emblem {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, var(--brand-royal), var(--brand-royal-light));
    color: var(--brand-gold);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.3s, color 0.3s;
  }
  .logo-text {
    display: flex;
    flex-direction: column;
  }
  .logo-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--brand-royal);
    letter-spacing: -0.3px;
    line-height: 1.2;
    transition: color 0.3s;
  }
  .logo-subtitle {
    font-size: 11px;
    color: var(--text-nav-muted);
    line-height: 1.3;
    letter-spacing: 0.2px;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-left: auto;
  }
  .nav-end {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
    position: relative;
    z-index: 115;
  }
  .nav-links-desktop {
    display: flex;
    list-style: none;
    gap: 2px;
    margin: 0;
    padding: 0;
    align-items: center;
  }

  .nav-link {
    position: relative;
    display: flex;
    align-items: center;
    padding: 8px 14px;
    color: var(--text-nav);
    text-decoration: none;
    font-size: 14px;
    font-weight: 450;
    border-radius: 6px;
    transition: color 0.2s, background 0.2s;
  }
  .nav-link .nav-indicator {
    position: absolute;
    bottom: 2px;
    left: 50%;
    transform: translateX(-50%) scaleX(0);
    width: 20px;
    height: 2.5px;
    background: var(--brand-gold);
    border-radius: 2px;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), background 0.3s;
  }
  .nav-link:hover {
    color: var(--brand-royal);
    background: color-mix(in srgb, var(--brand-royal) 8%, transparent);
  }
  .nav-link:hover .nav-indicator {
    transform: translateX(-50%) scaleX(1);
    background: var(--brand-royal);
  }
  .nav-link.active {
    color: var(--brand-gold);
    font-weight: 500;
  }
  .nav-link.active .nav-indicator {
    transform: translateX(-50%) scaleX(1);
    background: var(--brand-gold);
  }

  .btn-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0 20px;
    height: 36px;
    background: linear-gradient(135deg, var(--brand-royal), var(--brand-royal-light));
    color: #fff;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 0.2s, box-shadow 0.2s, background 0.3s;
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.2);
  }
  .btn-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(37, 99, 235, 0.3);
    background: linear-gradient(135deg, var(--brand-royal-hover), var(--brand-royal));
  }
  .btn-cta svg {
    transition: transform 0.2s;
  }
  .btn-cta:hover svg {
    transform: translateX(2px);
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    z-index: 110;
    border-radius: 6px;
    transition: background 0.15s;
  }
  .hamburger:hover {
    background: color-mix(in srgb, var(--brand-royal) 8%, transparent);
  }
  .hamburger:focus-visible {
    outline: 2px solid var(--brand-royal);
    outline-offset: 2px;
  }
  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--brand-royal);
    border-radius: 2px;
    transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center;
  }
  .hamburger.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }
  .hamburger.active span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .hamburger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  .nav-drawer {
    display: none;
  }

  @media (max-width: 1024px) {
    .nav-inner { padding: 0 20px; }
    .nav-right .nav-links-desktop { gap: 0; }
    .nav-right .nav-link { padding: 8px 10px; font-size: 13px; }
  }

  @media (max-width: 900px) {
    .nav-right { display: none; }
    .hamburger { display: flex; }

    .nav-drawer {
      position: fixed;
      top: 0;
      right: -100%;
      width: 300px;
      height: 100vh;
      background: var(--bg-drawer);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      display: flex;
      flex-direction: column;
      padding: 0;
      z-index: 105;
      transition: right 0.35s cubic-bezier(0.4, 0, 0.2, 1), background 0.3s;
      box-shadow: -8px 0 24px rgba(0,0,0,0.08);
      border-left: 1px solid var(--border-nav);
    }
    .nav-drawer.open { right: 0; }

    .drawer-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 24px 12px;
      border-bottom: 1px solid var(--border-soft);
    }
    .drawer-title {
      font-size: 14px;
      font-weight: 500;
      color: var(--text-nav-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .drawer-close {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border: none;
      background: var(--bg-hover);
      border-radius: 8px;
      cursor: pointer;
      color: var(--text-nav);
      transition: background 0.15s;
    }
    .drawer-close:hover { background: var(--border); }
    .drawer-close:focus-visible { outline: 2px solid var(--brand-royal); outline-offset: 2px; }

    .nav-drawer .nav-links {
      display: flex;
      flex-direction: column;
      list-style: none;
      padding: 8px 12px;
      margin: 0;
      gap: 2px;
      flex: 1;
    }
    .nav-drawer .nav-link {
      padding: 14px 16px;
      font-size: 15px;
      border-radius: 8px;
      justify-content: space-between;
    }
    .nav-drawer .nav-link .nav-indicator {
      position: static;
      transform: none;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: transparent;
      transition: background 0.2s;
    }
    .nav-drawer .nav-link.active .nav-indicator,
    .nav-drawer .nav-link:hover .nav-indicator {
      transform: none;
      background: var(--brand-gold);
    }

  }

  .nav-link:focus-visible {
    outline: 2px solid var(--brand-royal);
    outline-offset: 2px;
    border-radius: 6px;
  }
  .btn-cta:focus-visible {
    outline: 2px solid var(--brand-gold);
    outline-offset: 2px;
  }

  @media (max-width: 480px) {
    .nav-inner { padding: 0 16px; }
    .nav-drawer { width: 100%; }
    .logo-title { font-size: 14px; }
    .logo-subtitle { display: none; }
    .logo-emblem { width: 36px; height: 36px; }
  }
</style>
