---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Academics | JNV">
  <section class="page-hero">
    <div class="page-hero-bg" style="background-image: url('/images/Youth-Parliament-B2.jpg');"></div>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
      <span class="hero-badge">Academics</span>
      <h1 class="hero-title">Academic Excellence.</h1>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="section-header reveal reveal-up">
        <span class="section-eyebrow">Curriculum</span>
        <h2 class="section-title">CBSE-Affiliated Academic Program.</h2>
        <p class="section-desc">Our curriculum is designed to foster intellectual growth, critical thinking, and holistic development following the CBSE framework.</p>
      </div>

      <div class="academics-grid reveal-stagger">
        <div class="academic-card">
          <div class="academic-icon">
            <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"/></svg>
          </div>
          <h3>Secondary (VI–X)</h3>
          <p>Comprehensive education with Science, Mathematics, Social Science, Languages, and ICT as core subjects.</p>
        </div>
        <div class="academic-card">
          <div class="academic-icon">
            <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/></svg>
          </div>
          <h3>Senior Secondary (XI–XII)</h3>
          <p>Specialized streams in Science (PCM/B, PCB) and Humanities with experienced PGT faculty.</p>
        </div>
        <div class="academic-card">
          <div class="academic-icon">
            <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"/></svg>
          </div>
          <h3>Smart Classrooms</h3>
          <p>Technology-integrated teaching with digital boards, projectors, and e-learning resources for interactive lessons.</p>
        </div>
        <div class="academic-card">
          <div class="academic-icon">
            <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z"/></svg>
          </div>
          <h3>Lab Facilities</h3>
          <p>Well-equipped Physics, Chemistry, Biology, and Computer Science laboratories for practical learning.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-gray">
    <div class="section-inner">
      <div class="content-center">
        <span class="section-eyebrow">Examinations</span>
        <h2 class="section-title">Academic Calendar & Assessment.</h2>
        <p class="section-desc" style="max-width: 700px;">Regular assessments, periodic tests, and annual examinations are conducted as per CBSE guidelines. Our comprehensive evaluation system ensures continuous monitoring of student progress.</p>
        <div class="exam-grid reveal-stagger">
          <div class="exam-card">
            <h3>Periodic Tests</h3>
            <p>Conducted throughout the academic year to assess ongoing learning and identify areas for improvement.</p>
          </div>
          <div class="exam-card">
            <h3>Half-Yearly Exams</h3>
            <p>Comprehensive mid-session examinations covering the syllabus taught in the first half of the academic year.</p>
          </div>
          <div class="exam-card">
            <h3>Annual Exams</h3>
            <p>Final board examinations for Classes X and XII as per CBSE schedule; school-level exams for other classes.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    position: relative;
    height: 40vh;
    min-height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .page-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }
  .page-hero-overlay {
    position: absolute;
    inset: 0;
    background: var(--page-hero-overlay);
    z-index: 1;
    transition: background 0.3s;
  }
  .page-hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 24px;
  }
  .hero-badge {
    display: inline-block;
    font-size: 12px;
    font-weight: 500;
    color: #fff;
    background: rgba(37, 99, 235, 0.25);
    backdrop-filter: blur(12px);
    padding: 6px 18px;
    border-radius: 9999px;
    margin-bottom: 16px;
    text-transform: uppercase;
    letter-spacing: 1px;
    border: 1px solid rgba(255,255,255,0.2);
    box-shadow: 0 1px 4px rgba(0,0,0,0.1);
  }
  .hero-title {
    font-size: 44px;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -2.2px;
    color: #fff;
    margin: 0;
  }

  .section { padding: 96px 24px; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-gray {
    background: var(--bg-soft);
    transition: background 0.3s;
  }
  .section-header { text-align: center; margin-bottom: 48px; }
  .section-eyebrow {
    display: block;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    transition: color 0.3s;
  }
  .section-title {
    font-size: 32px;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -1.28px;
    color: var(--text);
    margin: 0 0 12px;
    transition: color 0.3s;
  }
  .section-desc {
    font-size: 16px;
    color: var(--text-3);
    margin: 0 auto;
    line-height: 1.5;
    transition: color 0.3s;
  }

  .academics-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .academic-card {
    background: var(--bg-card);
    border: 1px solid var(--border-soft);
    border-radius: 14px;
    padding: 36px 28px;
    box-shadow: var(--shadow-sm);
    transition: transform 0.4s, box-shadow 0.4s, border-color 0.3s, background 0.3s;
    position: relative;
    overflow: hidden;
  }
  .academic-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--gradient-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }
  .academic-card:hover::before {
    transform: scaleX(1);
  }
  .academic-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--bg-accent);
  }
  .academic-icon {
    width: 52px;
    height: 52px;
    background: var(--gradient-soft);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--brand-royal);
    box-shadow: var(--shadow-sm);
    margin-bottom: 20px;
    transition: color 0.3s, background 0.3s, box-shadow 0.3s, transform 0.3s;
  }
  .academic-card:hover .academic-icon {
    background: var(--gradient-primary);
    color: #fff;
    transform: scale(1.06);
    box-shadow: 0 4px 14px rgba(37, 99, 235, 0.2);
  }
  .academic-card h3 {
    font-size: 18px;
    font-weight: 600;
    color: var(--brand-royal);
    margin: 0 0 8px;
    transition: color 0.3s;
  }
  .academic-card p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-nav-muted);
    margin: 0;
    transition: color 0.3s;
  }

  .content-center {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .exam-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 40px;
    text-align: left;
  }
  .exam-card {
    background: var(--bg-card);
    border: 1px solid var(--border-soft);
    border-radius: 14px;
    padding: 28px;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.4s, transform 0.4s, border-color 0.3s, background 0.3s;
  }
  .exam-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
    border-color: var(--bg-accent);
  }
  .exam-card h3 {
    font-size: 15px;
    font-weight: 600;
    color: var(--brand-royal);
    margin: 0 0 8px;
    transition: color 0.3s;
  }
  .exam-card p {
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-nav-muted);
    margin: 0;
    transition: color 0.3s;
  }

  @media (max-width: 768px) {
    .hero-title { font-size: 30px; letter-spacing: -1.2px; }
    .section { padding: 64px 16px; }
    .academics-grid { grid-template-columns: 1fr; }
    .exam-grid { grid-template-columns: 1fr; }
  }
</style>
