---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | JNV">
  <section class="page-hero">
    <div class="page-hero-bg" style="background-image: url('/images/Youth-Parliament-B2.jpg');"></div>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
      <span class="hero-badge">Contact</span>
      <h1 class="hero-title">Get in Touch.</h1>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="contact-grid">
        <div class="contact-info reveal reveal-up">
          <span class="section-eyebrow">Reach Us</span>
          <h2 class="section-title">We'd Love to Hear From You.</h2>
          <p class="contact-desc">For admissions, inquiries, or any information about our school, please feel free to contact us.</p>

          <div class="contact-details">
            <div class="contact-item">
              <div class="contact-icon">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
              </div>
              <div>
                <h4>Address</h4>
                <p>Jawahar Navodaya Vidyalaya,<br />Cachar,<br />Assam, India</p>
              </div>
            </div>
            <div class="contact-item">
              <div class="contact-icon">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
              </div>
              <div>
                <h4>Phone</h4>
                <p>+91-XXX-XXXXXXX</p>
              </div>
            </div>
            <div class="contact-item">
              <div class="contact-icon">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
              </div>
              <div>
                <h4>Email</h4>
                <p>jnvbrp@gmail.com</p>
              </div>
            </div>
          </div>
        </div>

        <div class="contact-form reveal reveal-up">
          <form class="form-card" netlify>
            <h3>Send a Message</h3>
            <div class="form-group">
              <label for="name">Full Name</label>
              <input type="text" id="name" name="name" required placeholder="Your full name" />
            </div>
            <div class="form-group">
              <label for="email">Email Address</label>
              <input type="email" id="email" name="email" required placeholder="your@email.com" />
            </div>
            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone" placeholder="+91 XXX XXXXXXX" />
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" required placeholder="How can we help you?"></textarea>
            </div>
            <button type="submit" class="btn-submit">Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    position: relative;
    height: 40vh;
    min-height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .page-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }
  .page-hero-overlay {
    position: absolute;
    inset: 0;
    background: var(--page-hero-overlay);
    z-index: 1;
    transition: background 0.3s;
  }
  .page-hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 24px;
  }
  .hero-badge {
    display: inline-block;
    font-size: 12px;
    font-weight: 500;
    color: #fff;
    background: rgba(37, 99, 235, 0.25);
    backdrop-filter: blur(12px);
    padding: 6px 18px;
    border-radius: 9999px;
    margin-bottom: 16px;
    text-transform: uppercase;
    letter-spacing: 1px;
    border: 1px solid rgba(255,255,255,0.2);
    box-shadow: 0 1px 4px rgba(0,0,0,0.1);
  }
  .hero-title {
    font-size: 44px;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -2.2px;
    color: #fff;
    margin: 0;
  }

  .section { padding: 96px 24px; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-eyebrow {
    display: block;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    transition: color 0.3s;
  }
  .section-title {
    font-size: 32px;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -1.28px;
    color: var(--text);
    margin: 0 0 12px;
    transition: color 0.3s;
  }
  .contact-desc {
    font-size: 16px;
    color: var(--text-3);
    line-height: 1.5;
    margin: 0 0 40px;
    transition: color 0.3s;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .contact-item {
    display: flex;
    gap: 16px;
    align-items: start;
  }
  .contact-icon {
    width: 48px;
    height: 48px;
    background: var(--gradient-soft);
    border: none;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--brand-royal);
    box-shadow: var(--shadow-sm);
    flex-shrink: 0;
    transition: color 0.3s, background 0.3s, transform 0.3s, box-shadow 0.3s;
  }
  .contact-item:hover .contact-icon {
    background: var(--gradient-primary);
    color: #fff;
    transform: scale(1.06);
    box-shadow: 0 4px 14px rgba(37, 99, 235, 0.2);
  }
  .contact-item h4 {
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    margin: 0 0 4px;
    transition: color 0.3s;
  }
  .contact-item p {
    font-size: 14px;
    color: var(--text-3);
    margin: 0;
    line-height: 1.5;
    transition: color 0.3s;
  }

  .form-card {
    background: var(--bg-card);
    border: 1px solid var(--border-soft);
    border-radius: 14px;
    padding: 36px;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.3s, border-color 0.3s, background 0.3s;
  }
  .form-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--bg-accent);
  }
  .form-card h3 {
    font-size: 18px;
    font-weight: 600;
    color: var(--text);
    margin: 0 0 24px;
    transition: color 0.3s;
  }
  .form-group {
    margin-bottom: 20px;
  }
  .form-group label {
    display: block;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 6px;
    transition: color 0.3s;
  }
  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0 14px;
    height: 44px;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 14px;
    font-family: inherit;
    color: var(--text);
    background: var(--bg-card);
    transition: border-color 0.15s, background 0.3s, color 0.3s;
    box-sizing: border-box;
  }
  .form-group textarea {
    height: auto;
    padding: 12px 14px;
    resize: vertical;
  }
  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--brand-royal);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.08);
  }
  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--text-4);
  }
  .btn-submit {
    width: 100%;
    justify-content: center;
    border: none;
    cursor: pointer;
    border-radius: 100px;
    height: 48px;
    font-size: 16px;
    font-weight: 500;
    background: var(--gradient-primary);
    color: #fff;
    box-shadow: 0 4px 14px rgba(37, 99, 235, 0.2);
    transition: box-shadow 0.2s, transform 0.2s;
    font-family: inherit;
  }
  .btn-submit:hover {
    box-shadow: 0 6px 24px rgba(37, 99, 235, 0.3);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .hero-title { font-size: 30px; letter-spacing: -1.2px; }
    .section { padding: 64px 16px; }
    .contact-grid { grid-template-columns: 1fr; gap: 40px; }
  }
</style>
