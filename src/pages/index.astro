---
import Layout from '../layouts/Layout.astro';
---

<Layout title="JNV Barpeta Road | Jawahar Navodaya Vidyalaya">
  <section class="hero">
    <div class="hero-bg" style="background-image: url('/images/Youth-Parliament-B2.jpg');"></div>
    <div class="hero-overlay"></div>
    <div class="particles" id="particles"></div>
    <div class="hero-content">
      <span class="hero-badge">Navodaya Vidyalaya Samiti</span>
      <h1 class="hero-title">Jawahar Navodaya<br />Vidyalaya.</h1>
      <p class="hero-desc">A residential co-educational school under the Ministry of Education, Government of India. Nurturing talent, building character, shaping futures.</p>
      <div class="hero-cta">
        <a href="/about" class="btn btn-primary">Explore More</a>
        <a href="/contact" class="btn btn-secondary">Get in Touch</a>
      </div>
    </div>
  </section>

  <section class="section stats">
    <div class="section-inner">
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-number">1996</span>
          <span class="stat-label">Established</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">600+</span>
          <span class="stat-label">Students</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">25+</span>
          <span class="stat-label">Faculty</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">100%</span>
          <span class="stat-label">Pass Percentage</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section about">
    <div class="section-inner">
      <div class="about-grid">
        <div class="about-text">
          <span class="section-eyebrow">About Our School</span>
          <h2 class="section-title">A Tradition of Excellence in Education.</h2>
          <p>Jawahar Navodaya Vidyalaya, Barpeta Road is a residential co-educational school established in 1996. Part of the Navodaya Vidyalaya Samiti, our school provides quality education to talented students from rural areas, fostering all-round development through academic excellence, sports, and cultural activities.</p>
          <p>With a sprawling campus, dedicated faculty, and a nurturing environment, we are committed to shaping responsible citizens and future leaders of India.</p>
          <a href="/about" class="btn btn-primary">Learn More</a>
        </div>
        <div class="about-image" style="background-image: url('/images/matti_1.jpeg');"></div>
      </div>
    </div>
  </section>

  <section class="section features">
    <div class="section-inner">
      <div class="features-header">
        <span class="section-eyebrow">Why JNV</span>
        <h2 class="section-title">What Makes Us Unique.</h2>
      </div>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M12 14l9-5-9-5-9 5 9 5z"/><path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
          </div>
          <h3>Quality Education</h3>
          <p>CBSE-affiliated curriculum with focus on academic excellence and holistic development.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
          </div>
          <h3>Dedicated Faculty</h3>
          <p>Experienced and passionate teachers committed to nurturing every student's potential.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/></svg>
          </div>
          <h3>Modern Campus</h3>
          <p>Well-equipped laboratories, library, sports facilities, and smart classrooms for modern learning.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M10.752 6.164c-.092-.755-.622-1.36-1.32-1.594-.73-.244-1.512-.063-2.07.34-.448.324-.828.8-1.07 1.367m3.31 4.589c.092.755.622 1.36 1.32 1.594.73.244 1.512.063 2.07-.34.448-.324.828-.8 1.07-1.367m-3.31-4.589c.783 1.107 1.477 2.201 2.083 3.303m-4.504-4.133c.418 1.391.975 2.748 1.676 4.003m-3.189-5.18A11.931 11.931 0 003.75 12c0 2.181.437 4.258 1.23 6.19m9.512-9.512c-1.054 1.42-2.35 2.645-3.846 3.632m3.846-3.632A11.968 11.968 0 0112 3.75a11.93 11.93 0 00-3.846 3.632m5.13 5.13A11.984 11.984 0 0112 20.25a11.93 11.93 0 01-3.846-3.632m5.13-5.13a11.984 11.984 0 013.846-3.632M8.154 16.616c.418-1.391.975-2.748 1.676-4.003M8.154 16.616a11.97 11.97 0 01-1.23 6.19"/></svg>
          </div>
          <h3>Cultural Growth</h3>
          <p>Vibrant cultural programs, youth parliaments, NSS, and clubs that build well-rounded personalities.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section cta-band">
    <div class="section-inner">
      <div class="cta-content">
        <h2 class="cta-title">Ready to Join Our School Community?</h2>
        <p class="cta-desc">Admissions open for Class VI through JNVST (Jawahar Navodaya Vidyalaya Selection Test).</p>
        <a href="/contact" class="btn btn-primary btn-white">Contact Us</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const particleContainer = document.getElementById('particles');
  if (particleContainer) {
    var count = window.innerWidth < 768 ? 20 : 40;
    for (var i = 0; i < count; i++) {
      var p = document.createElement('div');
      p.className = 'particle';
      var x = Math.random() * 100;
      var y = Math.random() * 100;
      var size = Math.random() * 3 + 1;
      var dur = Math.random() * 6 + 4;
      var delay = Math.random() * 5;
      p.style.cssText = 'left:' + x + '%;top:' + y + '%;width:' + size + 'px;height:' + size + 'px;animation-duration:' + dur + 's;animation-delay:' + delay + 's';
      particleContainer.appendChild(p);
    }
  }
</script>

<style>
  .hero {
    position: relative;
    height: 90vh;
    min-height: 580px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    transform: scale(1.05);
    animation: heroZoom 20s ease-in-out infinite alternate;
  }
  @keyframes heroZoom {
    0% { transform: scale(1.05); }
    100% { transform: scale(1.15); }
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: var(--hero-overlay);
    z-index: 1;
    transition: background 0.3s;
  }
  .particles {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }
  .particle {
    position: absolute;
    background: var(--particle-bg);
    border-radius: 50%;
    animation: floatParticle linear infinite;
  }
  @keyframes floatParticle {
    0%, 100% { transform: translateY(0) translateX(0); opacity: 0.3; }
    25% { transform: translateY(-30px) translateX(15px); opacity: 0.7; }
    50% { transform: translateY(-10px) translateX(-10px); opacity: 0.5; }
    75% { transform: translateY(-40px) translateX(5px); opacity: 0.8; }
  }
  .hero-content {
    position: relative;
    z-index: 3;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    padding: 0 24px;
  }
  .hero-badge {
    display: inline-block;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-hero);
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(8px);
    padding: 6px 16px;
    border-radius: 9999px;
    margin-bottom: 28px;
    text-transform: uppercase;
    letter-spacing: 1px;
    border: 1px solid rgba(255,255,255,0.15);
    animation: fadeUp 0.8s ease-out both;
  }
  .hero-title {
    font-size: 56px;
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -2.8px;
    color: #fff;
    margin: 0 0 20px;
    animation: fadeUp 0.8s ease-out 0.15s both;
  }
  .hero-desc {
    font-size: 18px;
    line-height: 1.6;
    color: var(--text-hero-strong);
    max-width: 600px;
    margin: 0 auto 36px;
    animation: fadeUp 0.8s ease-out 0.3s both;
  }
  .hero-cta {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    animation: fadeUp 0.8s ease-out 0.45s both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0 28px;
    height: 48px;
    border-radius: 100px;
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-primary {
    background: var(--hero-btn-bg);
    color: var(--hero-btn-text);
    transition: background 0.2s, color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .btn-primary:hover {
    background: var(--hero-btn-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px var(--hero-btn-shadow);
  }
  .btn-secondary {
    background: var(--hero-btn-secondary-bg);
    backdrop-filter: blur(8px);
    color: #fff;
    border: 1px solid var(--hero-btn-secondary-border);
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
  }
  .btn-secondary:hover {
    background: rgba(255,255,255,0.2);
    transform: translateY(-1px);
  }
  .btn-white {
    background: var(--cta-btn-bg);
    color: var(--cta-btn-text);
    transition: background 0.2s, color 0.2s, transform 0.2s;
  }
  .btn-white:hover {
    background: var(--cta-btn-hover);
    transform: translateY(-1px);
  }

  .section {
    padding: 96px 24px;
  }
  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .section-eyebrow {
    display: block;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    transition: color 0.3s;
  }
  .section-title {
    font-size: 32px;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -1.28px;
    color: var(--text);
    margin: 0 0 24px;
    transition: color 0.3s;
  }

  .stats {
    background: var(--bg-card);
    padding: 48px 24px;
    transition: background 0.3s;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .stat-card {
    text-align: center;
    padding: 32px 16px;
    background: var(--bg-soft);
    border-radius: 8px;
    border: 1px solid var(--border);
    transition: background 0.3s, border-color 0.3s;
  }
  .stat-number {
    display: block;
    font-size: 36px;
    font-weight: 600;
    letter-spacing: -1.44px;
    color: var(--text);
    line-height: 1;
    margin-bottom: 8px;
    transition: color 0.3s;
  }
  .stat-label {
    font-size: 14px;
    color: var(--text-3);
    transition: color 0.3s;
  }

  .about {
    background: var(--bg);
    transition: background 0.3s;
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .about-text p {
    font-size: 16px;
    line-height: 1.6;
    color: var(--text-2);
    margin: 0 0 16px;
    transition: color 0.3s;
  }
  .about-text .btn {
    margin-top: 16px;
  }
  .about-image {
    width: 100%;
    aspect-ratio: 4/3;
    border-radius: 12px;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .features {
    background: var(--bg-card);
    transition: background 0.3s;
  }
  .features-header {
    text-align: center;
    margin-bottom: 48px;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .feature-card {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 24px;
    transition: box-shadow 0.2s, transform 0.2s, background 0.3s, border-color 0.3s;
  }
  .feature-card:hover {
    box-shadow: 0 2px 2px rgba(0,0,0,0.03), 0 8px 16px -4px rgba(0,0,0,0.04);
    transform: translateY(-2px);
  }
  .feature-icon {
    width: 40px;
    height: 40px;
    background: var(--bg-card);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text);
    border: 1px solid var(--border);
    margin-bottom: 16px;
    transition: background 0.3s, border-color 0.3s, color 0.3s;
  }
  .feature-card h3 {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.36px;
    color: var(--text);
    margin: 0 0 8px;
    transition: color 0.3s;
  }
  .feature-card p {
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-3);
    margin: 0;
    transition: color 0.3s;
  }

  .cta-band {
    background: var(--bg-inverse);
    text-align: center;
    transition: background 0.3s;
  }
  .cta-content {
    max-width: 600px;
    margin: 0 auto;
  }
  .cta-title {
    font-size: 32px;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -1.28px;
    color: #fff;
    margin: 0 0 16px;
  }
  .cta-desc {
    font-size: 16px;
    line-height: 1.6;
    color: rgba(255,255,255,0.7);
    margin: 0 0 32px;
  }

  @media (max-width: 768px) {
    .hero { height: 80vh; min-height: 480px; }
    .hero-title { font-size: 34px; letter-spacing: -1.4px; }
    .hero-desc { font-size: 16px; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .about-grid { grid-template-columns: 1fr; gap: 32px; }
    .features-grid { grid-template-columns: 1fr; }
    .section { padding: 64px 16px; }
    .stat-number { font-size: 28px; }
  }
</style>
