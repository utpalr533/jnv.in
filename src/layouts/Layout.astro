---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'JNV Barpeta Road', description = 'Jawahar Navodaya Vidyalaya, Barpeta Road, Assam — A residential co-educational school under Navodaya Vidyalaya Samiti.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <script is:inline>
      (function() {
        var pref = localStorage.getItem('theme-preference');
        if (!pref) pref = 'system';
        var theme = pref;
        if (pref === 'system') {
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        document.documentElement.setAttribute('data-theme-preference', pref);
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
  </body>
</html>

<style>
  :root {
    --bg: #fafafa;
    --bg-card: #ffffff;
    --bg-soft: #fafafa;
    --bg-hover: #f5f5f5;
    --bg-inverse: #171717;
    --bg-nav: rgba(255, 255, 255, 0.88);
    --bg-drawer: rgba(255, 255, 255, 0.98);

    --text: #171717;
    --text-2: #4d4d4d;
    --text-3: #888888;
    --text-4: #a1a1a1;
    --text-nav: #4b5563;
    --text-nav-muted: #6b7280;
    --text-inverse: #ffffff;
    --text-hero: rgba(255, 255, 255, 0.7);
    --text-hero-strong: rgba(255, 255, 255, 0.75);

    --brand-navy: #0f2b5e;
    --brand-navy-light: #1a3a6e;
    --brand-navy-hover: #14366e;
    --brand-navy-hover-2: #1f4480;
    --brand-gold: #c9a84c;

    --border: #ebebeb;
    --border-soft: #f0f0f0;
    --border-nav: rgba(235, 235, 235, 0.6);

    --hero-overlay: linear-gradient(135deg, rgba(10,10,35,0.85) 0%, rgba(0,0,0,0.7) 50%, rgba(10,10,35,0.6) 100%);
    --page-hero-overlay: linear-gradient(135deg, rgba(10,10,35,0.85) 0%, rgba(0,0,0,0.6) 100%);

    --particle-bg: rgba(255,255,255,0.5);

    --hero-btn-bg: #ffffff;
    --hero-btn-text: #171717;
    --hero-btn-hover: #e6e6e6;
    --hero-btn-shadow: rgba(0,0,0,0.2);
    --hero-btn-secondary-bg: rgba(255,255,255,0.1);
    --hero-btn-secondary-border: rgba(255,255,255,0.25);

    --cta-btn-bg: #ffffff;
    --cta-btn-text: #171717;
    --cta-btn-hover: #e6e6e6;
  }

  [data-theme="dark"] {
    --bg: #0f172a;
    --bg-card: #1e293b;
    --bg-soft: #1e293b;
    --bg-hover: #334155;
    --bg-inverse: #1e293b;
    --bg-nav: rgba(15, 23, 42, 0.9);
    --bg-drawer: rgba(15, 23, 42, 0.98);

    --text: #f8fafc;
    --text-2: #cbd5e1;
    --text-3: #94a3b8;
    --text-4: #64748b;
    --text-nav: #cbd5e1;
    --text-nav-muted: #94a3b8;
    --text-inverse: #ffffff;
    --text-hero: rgba(255, 255, 255, 0.7);
    --text-hero-strong: rgba(255, 255, 255, 0.75);

    --brand-navy: #3b82f6;
    --brand-navy-light: #60a5fa;
    --brand-navy-hover: #3b82f6;
    --brand-navy-hover-2: #60a5fa;
    --brand-gold: #fbbf24;

    --border: #334155;
    --border-soft: #2d3a4e;
    --border-nav: rgba(51, 65, 85, 0.6);

    --hero-overlay: linear-gradient(135deg, rgba(5,10,25,0.92) 0%, rgba(0,0,0,0.8) 50%, rgba(5,10,25,0.7) 100%);
    --page-hero-overlay: linear-gradient(135deg, rgba(5,10,25,0.92) 0%, rgba(0,0,0,0.7) 100%);

    --particle-bg: rgba(255,255,255,0.12);

    --hero-btn-bg: #1e293b;
    --hero-btn-text: #f8fafc;
    --hero-btn-hover: #334155;
    --hero-btn-shadow: rgba(0,0,0,0.4);
    --hero-btn-secondary-bg: rgba(255,255,255,0.08);
    --hero-btn-secondary-border: rgba(255,255,255,0.2);

    --cta-btn-bg: #ffffff;
    --cta-btn-text: #0f172a;
    --cta-btn-hover: #e6e6e6;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    transition: color 0.3s, background-color 0.3s;
  }

  body {
    margin: 0;
    font-family: Inter, system-ui, -apple-system, sans-serif;
    font-size: 16px;
    line-height: 1.5;
    color: var(--text);
    background: var(--bg);
    transition: color 0.3s, background-color 0.3s;
  }

  ::selection {
    background: var(--text);
    color: var(--bg);
  }
</style>
